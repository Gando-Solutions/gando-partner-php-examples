{
    "name": "gando/partner-webhook-symfony-example",
    "description": "Symfony webhook receiver example for Gando Partner API",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "gando/partner-symfony": "^0.1.4",
        "symfony/cache": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/monolog-bundle": "^3.10",
        "symfony/runtime": "^7.0",
        "symfony/string": "^7.4",
        "symfony/yaml": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/runtime": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
