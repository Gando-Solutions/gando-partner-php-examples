{
    "name": "gando/partner-php-examples",
    "description": "Runnable examples for the Gando Partner PHP SDK",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "gando/partner": "^0.1.10",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}